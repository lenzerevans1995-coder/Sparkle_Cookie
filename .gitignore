# ---- Re-include OUR custom folder (code + data only) ----
!/Assets/SparkleCookie/
!/Assets/SparkleCookie/**

# Within our folder, still keep binaries out of git (recipes are documented in text)
/Assets/SparkleCookie/**/*.png
/Assets/SparkleCookie/**/*.jpg
/Assets/SparkleCookie/**/*.fbx
/Assets/SparkleCookie/**/*.wav
